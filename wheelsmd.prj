"but","diameterCalcBtn",1106,28,92,24,104,#TRUE#,2,"Calculate",0,0,0
"Sub object1106()
	'find tire diameter
	Dim width as Double, aspect as Double, rim as Double, diam as Double

    width = Val(fldTireWidth.Text)

    aspect = Val(fldAspectRatio.Text)

    rim = Val(fldRimSize.Text)

    diam = (((width * (aspect / 100)) / 25.4) * 2) + rim

    fldDiameter.Text = Str(Round(diam, 2)) + ~ in~
End Sub"
