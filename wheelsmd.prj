"but","speedoCalcBtn",1120,28,100,24,104,#TRUE#,2,"Calculate",0,0,0
"Sub object1120()
	'calc speedometer error %
	
	Dim oldD as Double, newD as Double, err as Double

    oldD = Val(fldOldD.Text)

    newD = Val(fldNewD.Text)

    err = ((newD - oldD) / oldD) * 100

    fldSpeedo.Text = Str(Round(err, 2)) + ~%~
End Sub"
