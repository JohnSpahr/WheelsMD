"but","dispCalcBtn",1019,28,96,24,104,#TRUE#,2,"Calculate",0,0,0
"Sub object1019()
	'find engine displacement
	Dim bore as Double, stroke as Double, cyl as Double, disp as Double

    bore = Val(fldBore.Text)

    stroke = Val(fldStrokeDisp.Text)

    cyl = Val(fldCyl.Text)

    disp = stroke * 3.14159 * (bore / 2)^2 * cyl

    fldDisplacement.Text = Str(Round(disp, 0)) + ~ cc~
End Sub"
