"Sub object1221()
	'coolant/fluid mix ratio
	Dim capacity as Double, targetPct as Double, concentrate as Double

    capacity = Val(fldCapacity.Text)

    targetPct = Val(fldPercent.Text) ' Enter 50 for a 50/50 mix

    concentrate = capacity * (targetPct / 100)

    fldConc.Text = Str(Round(concentrate, 1))
End Sub"
