"but","ampFuseCalcBtn",1148,28,56,24,104,#TRUE#,2,"Calculate",0,0,0
"Sub object1148()
	'amps and fuse calc
	Dim watts as Double, volts as Double, amps as Double, fuse as Double

    watts = Val(fldWatts.Text)

    volts = Val(fldVolts.Text) ' Typically 12.0 or 14.4 for cars

    amps = watts / volts

    fuse = amps * 1.35

    fldResultAmps.Text = Str(Round(amps, 1))

    fldResultFuse.Text = Str(Round(fuse, 0))

End Sub"
