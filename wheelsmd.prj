"but","torqueCalcBtn",1131,28,96,24,104,#TRUE#,2,"Calculate",0,0,0
"Sub object1131()
	'calc torque conversion
	Dim inputVal as Double

    inputVal = Val(fldTorqueCon.Text)

    If torquePopup.Text = ~NM~ Then
    	'to nm
        fldTorqueRes.Text = Str(Round((inputVal * 1.355818), 1)) + ~ NM~
    Else
    	'to pound feet
        fldTorqueRes.Text = Str(Round((inputVal * 0.737562), 1)) + ~ ft-lbs~
    End If
End Sub"
