"but","horsepowerCalcBtn",1016,28,92,24,104,#TRUE#,2,"Calculate",0,0,0
"Sub object1016()
	'calc hp
	Dim torque as Double, rpm as Double, hp as Double
	torque = Val(fldTorque.Text)
	rpm = Val(fldHpRPM.Text)
	hp = (torque * rpm) / 5252
	fldHorsepower.Text = Str(Round(hp, 1)) + ~ HP~
End Sub"
