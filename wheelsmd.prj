"but","pistonCalcBtn",1024,28,96,24,104,#TRUE#,2,"Calculate",0,0,0
"Sub object1024()
	'find piston mean speed
	Dim stroke as Double, rpm as Double, mps as Double

    stroke = Val(fldStrokePiston.Text)

    rpm = Val(fldRPMPiston.Text)

    mps = (stroke * 2 * rpm) / 12

    fldPiston.Text = Str(Round(mps, 1)) + ~ fpm~
End Sub"
