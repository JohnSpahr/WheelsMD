"Sub object1207()
	'vol calc
	Dim qts as Double, liters as Double, ml as Double

    qts = Val(fldQts.Text)

    liters = qts * 0.946353

    ml = liters * 1000

    fldLiters.Text = Str(Round(liters, 1)) + ~ L~

    fldML.Text = Str(Round(ml, 0)) + ~ mL~
End Sub"
