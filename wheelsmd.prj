"but","compCalcBtn",1102,28,96,24,104,#TRUE#,2,"Calculate",0,0,0
"Sub object1102()
	'find compression ratio
	Dim swept as Double, clearance as Double, cr as Double

    swept = Val(fldCompSwept.Text)

    clearance = Val(fldCompClearance.Text)

    cr = (swept + clearance) / clearance

    fldCompression.Text = Str(Round(cr, 2))
End Sub"
